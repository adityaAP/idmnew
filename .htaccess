<IfModule mod_rewrite.c>
  RewriteEngine On

  # Subdomain or domain root (e.g. old.ptintandayamandiri.co.id):
  RewriteBase /

  # Subfolder install only — comment line above and uncomment below:
  # RewriteBase /idm-home/

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ index.php/$1 [L,QSA]

  Options -Indexes
</IfModule>

<IfModule !mod_rewrite.c>
  ErrorDocument 404 /index.php
</IfModule>

# Production — hide PHP errors on live server
<IfModule mod_env.c>
  SetEnv CI_ENV production
</IfModule>
